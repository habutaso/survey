datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  surveyor
  admin
  viewer
}

model User {
  id          String   @id
  email       String
  signInName  String
  displayName String
  photoUrl    String?
  createdAt   DateTime
  roles       Role[]   @default([])
}
